# Copy to .env.local and fill in. .env.local is gitignored and never leaves your machine.

# Google Gemini API key — used server-side only for chat generation and corpus/query
# embeddings (from TASK-006 on). Never expose to the client; never prefix with NEXT_PUBLIC_.
GEMINI_API_KEY=

# Hunter Wumpus game backend base URL (the Hugging Face Space). Public by design.
NEXT_PUBLIC_WUMPUS_API=
