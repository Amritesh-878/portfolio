# Copy to .env.local and fill in. .env.local is gitignored and never leaves your machine.

# Google Gemini API key. Used server-side only, for the RAG indexer (npm run build:index)
# and the AI-twin chat API. Never expose to the client; never prefix with NEXT_PUBLIC_.
GEMINI_API_KEY=

# Hunter Wumpus game backend base URL (the Hugging Face Space). Public by design.
NEXT_PUBLIC_WUMPUS_API=

# Web3Forms access key for the contact form. Public by design (client-side); not a secret.
# Get a free key at https://web3forms.com
NEXT_PUBLIC_WEB3FORMS_KEY=
