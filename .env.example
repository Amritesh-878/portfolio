# Copy to .env.local and fill in. .env.local is gitignored and never leaves your machine.

# Google Gemini API key. Used server-side only, for the RAG indexer (npm run build:index)
# and the AI-twin chat API. Never expose to the client; never prefix with NEXT_PUBLIC_.
GEMINI_API_KEY=

# Hunter Wumpus game backend base URL (the Hugging Face Space). Public by design.
NEXT_PUBLIC_WUMPUS_API=

# Contact form: owned pipeline (Resend to send, Cloudflare Turnstile to verify).
# Resend API key (Sending access), from resend.com. Server-side only; never NEXT_PUBLIC_.
RESEND_API_KEY=
# Cloudflare Turnstile secret key, for server-side token verification. Never NEXT_PUBLIC_.
TURNSTILE_SECRET_KEY=
# Cloudflare Turnstile site key, rendered in the browser. Public by design.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Where contact-form mail is delivered: your real inbox. Server-side so it stays off the public site.
CONTACT_TO_EMAIL=
