# Generated RAG index: committed so code/asset deploys don't re-embed (and hit the
# free-tier embedding quota); rebuilt by `npm run build:index` when the corpus changes.
src/generated/*
!src/generated/rag-index.json

# Fumadocs MDX generated source (rebuilt by the postinstall/build hook)
.source/

# Local, unpublished source drafts for the AI-twin corpus
content/ai-twin/sources/

# OS noise
Thumbs.db
.DS_Store
